WiFiClientSecure espClient;
PubSubClient client(espClient);

// --- 3. HELPER FUNCTIONS ---

void syncTime() {
  configTime(0, 0, "pool.ntp.org", "time.google.com");
  Serial.print("Syncing Clock for TLS: ");
  time_t now = time(nullptr);
  while (now < 1672531200) { 
    delay(500);
    Serial.print(".");
    now = time(nullptr);
  }
  Serial.println("\n[OK] Time Synced.");
}

void setup_wifi() {
  delay(10);
  Serial.print("Connecting to WiFi...");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) { 
    delay(500); 
    Serial.print(".");
  }
  Serial.println("\nWiFi connected.");
}

void reconnect() {
  while (!client.connected()) {
    Serial.print("Attempting STRICT mTLS connection...");
    if (client.connect(mqtt_client_id)) {
      Serial.println("CONNECTED SECURELY!");
      // Optional: publish initial state upon connection
      client.publish(mqtt_publish_topic, "Sink Sensor Online");
    } else {
      Serial.print("failed, rc=");
      Serial.print(client.state());
      Serial.println(" - Retrying in 5s...");
      delay(5000); 
    }
  }
}

// --- 4. MAIN LOGIC ---

void setup() {
  Serial.begin(115200);
  analogSetAttenuation(ADC_11db);
  
  setup_wifi();
  syncTime();

  // Load the Security Trio
  espClient.setCACert(root_ca); 
  espClient.setCertificate(client_cert); 
  espClient.setPrivateKey(client_key);   
  
  // ESP32 v3.0 Handshake fix
  espClient.setHandshakeTimeout(45); 

  client.setServer(mqtt_server, 8883); // Using secure port
  Serial.println("Bathroom Sink Secure Monitor Active.");
}

void loop() {
  if (!client.connected()) reconnect();
  client.loop();

  int val = analogRead(waterSensorPin);

  WaterState newState = currentState;

  if (val < threshold_Flood) {
    newState = FLOOD_ALERT;
  } 
  else if (val < threshold_WaterPresent && val >= (threshold_Flood + hysteresis)) {
    newState = WATER_PRESENT;
  } 
  else if (val >= (threshold_WaterPresent + hysteresis)) {
    newState = DRY;
  }

  // Event Driven: Only publish on state change
  if (newState != lastState) {
    String message;
    if (newState == DRY)           message = "Dry";
    if (newState == WATER_PRESENT) message = "Water Detected";
    if (newState == FLOOD_ALERT)   message = "FLOOD ALERT";

    Serial.print("Secure Transition to: ");
    Serial.println(message);
    
    client.publish(mqtt_publish_topic, message.c_str());
    
    lastState = newState;
    currentState = newState;
  }

  delay(500); 
}
