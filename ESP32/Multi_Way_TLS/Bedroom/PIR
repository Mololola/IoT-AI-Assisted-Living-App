WiFiClientSecure espClient;
PubSubClient client(espClient);

RoomState currentRoomState = OUT;
bool lastPIRState = LOW; 
long lastMotionTime = 0; 

// --- Function Prototypes ---
void publishState(const char* state_str);
void setup_wifi();
void reconnect();

// ------------------------------------
// 3. HELPER FUNCTIONS
// ------------------------------------

void syncTime() {
    configTime(0, 0, "pool.ntp.org", "time.google.com");
    Serial.print("Syncing Clock for TLS: ");
    time_t now = time(nullptr);
    while (now < 1672531200) { 
        delay(500);
        Serial.print(".");
        now = time(nullptr);
    }
    Serial.println("\n[OK] Time Synced.");
}

void setup_wifi() {
    delay(10);
    Serial.print("Connecting to ");
    Serial.println(ssid);
    
    WiFi.begin(ssid, password);
    
    while (WiFi.status() != WL_CONNECTED) {
        delay(500);
        Serial.print(".");
    }

    Serial.println("");
    Serial.println("WiFi connected");
    Serial.print("IP address: ");
    Serial.println(WiFi.localIP());
}

void reconnect() {
    while (!client.connected()) {
        Serial.print("Attempting STRICT mTLS connection...");
        
        if (client.connect(mqtt_client_id)) {
            Serial.println("connected securely to broker!");
            client.publish("home/status", "ESP32 Bedroom PIR Sensor Online");
        } else {
            Serial.print("failed, rc=");
            Serial.print(client.state());
            Serial.println(" trying again in 5 seconds");
            delay(5000);
        }
    }
}

// ------------------------------------
// 4. PUBLISHING LOGIC
// ------------------------------------
void publishState(const char* state_str) {
    if (client.connected()) {
        client.publish(mqtt_publish_topic, state_str);
        Serial.print("Secure MQTT Pub: State changed to ");
        Serial.println(state_str);
    }
}

// ------------------------------------
// 5. MAIN LOGIC: Event-Driven State Handler
// ------------------------------------
void handleMotionDetection() {
    long currentTime = millis();
    bool currentPIRState = digitalRead(PIR_PIN);

    if (currentPIRState == HIGH && lastPIRState == LOW && (currentTime - lastMotionTime > DEBOUNCE_DELAY_MS)) {
        
        lastMotionTime = currentTime; 
        
        if (currentRoomState == OUT) {
            currentRoomState = IN;
            Serial.println(">>> State Change: IN (Movement Detected)");
            publishState("IN");
        } else {
            currentRoomState = OUT;
            Serial.println(">>> State Change: OUT (Movement Detected - Toggling out)");
            publishState("OUT");
        }
    }
    lastPIRState = currentPIRState;
}

// ------------------------------------
// 6. SETUP & LOOP
// ------------------------------------
void setup() {
    Serial.begin(115200); 
    pinMode(PIR_PIN, INPUT); 
    
    Serial.println("PIR State Toggle Initialized.");
    
    setup_wifi();
    syncTime();

    // Load the Security Trio
    espClient.setCACert(root_ca); 
    espClient.setCertificate(client_cert); 
    espClient.setPrivateKey(client_key);   
    
    // ESP32 v3.0 Handshake fix
    espClient.setHandshakeTimeout(45); 

    client.setServer(mqtt_server, 8883); // Secure Port
    
    Serial.print("Initial State: ");
    Serial.println(currentRoomState == IN ? "IN" : "OUT");
}

void loop() {
    if (!client.connected()) {
        reconnect();
    }
    client.loop(); 

    handleMotionDetection();

    delay(100); 
}
