// --- 3. HELPER FUNCTIONS ---

void syncTime() {
  configTime(0, 0, "pool.ntp.org", "time.google.com");
  Serial.print("Syncing Clock for TLS: ");
  time_t now = time(nullptr);
  while (now < 1672531200) { 
    delay(500);
    Serial.print(".");
    now = time(nullptr);
  }
  Serial.println("\n[OK] Time Synced.");
}

void setup_wifi() { 
  delay(10);
  Serial.print("Connecting to ");
  Serial.println(ssid);
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi connected");
}

// --- 4. SECURE MQTT COMMAND HANDLER ---

void callback(char* topic, byte* payload, unsigned int length) {
  String message;
  for (int i = 0; i < length; i++) {
    message += (char)payload[i];
  }
  message.toUpperCase();

  Serial.println("Secure Message arrived [" + String(topic) + "]: " + message);

  if (message == "ON" || message == "1") {
    for(int i=0; i<NUM_LEDS; i++) {
      strip.setPixelColor(i, strip.Color(255, 255, 255)); // White
    }
    strip.show();
    
    // Publish dynamic status string including the client ID
    String statusMsg = String(mqtt_client_id) + " ON";
    client.publish(topic_status, statusMsg.c_str());
  } 
  else if (message == "OFF" || message == "0") { 
    strip.clear();
    strip.show();
    
    String statusMsg = String(mqtt_client_id) + " OFF";
    client.publish(topic_status, statusMsg.c_str());
  }
}

void reconnect() {
  while (!client.connected()) {
    Serial.print("Attempting STRICT mTLS connection...");
    
    if (client.connect(mqtt_client_id)) {
      Serial.println("connected securely!");
      client.subscribe(topic_cmd);
      Serial.println("Subscribed to command topic.");
    } else {
      Serial.print("failed, rc=");
      Serial.print(client.state());
      delay(5000);
    }
  }
}

// --- 5. SETUP & LOOP ---

void setup() {
  Serial.begin(115200);
  
  strip.begin();
  strip.setBrightness(100); 
  strip.show(); // Start OFF

  setup_wifi();
  syncTime();

  // Load the Security Trio
  espClient.setCACert(root_ca); 
  espClient.setCertificate(client_cert); 
  espClient.setPrivateKey(client_key);   
  
  espClient.setHandshakeTimeout(45); 

  client.setServer(mqtt_server, 8883); // Secure Port
  client.setCallback(callback);
}

void loop() {
  if (!client.connected()) {
    reconnect();
  }
  client.loop();
}
