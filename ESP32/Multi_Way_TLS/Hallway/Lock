// --- 3. HELPER FUNCTIONS ---

void syncTime() {
    configTime(0, 0, "pool.ntp.org", "time.google.com");
    Serial.print("Syncing Clock for TLS (May take longer at 80MHz): ");
    time_t now = time(nullptr);
    while (now < 1672531200) { 
        delay(500);
        Serial.print(".");
        now = time(nullptr);
    }
    Serial.println("\n[OK] Time Synced.");
}

void setup_wifi() {
    delay(10);
    WiFi.setSleep(true); // Enable Modem Sleep 
    WiFi.begin(ssid, password);
    
    int retry_count = 0;
    while (WiFi.status() != WL_CONNECTED && retry_count < 20) { 
        delay(500); 
        Serial.print("."); 
        retry_count++;
    }
    
    if (WiFi.status() == WL_CONNECTED) {
        WiFi.setTxPower(WIFI_POWER_8_5dBm); // Save ~80mA spikes
        Serial.println("\nWiFi Connected");
    }
}

// --- 4. SECURE MQTT COMMAND HANDLER ---
void callback(char* topic, byte* payload, unsigned int length) {
    String message;
    for (int i = 0; i < length; i++) { message += (char)payload[i]; }
    message.toUpperCase();

    Serial.println("Secure Lock Command Received: " + message);

    if (message == "UNLOCK" || message == "U") {
        Serial.println("[EVENT] SECURE Pulse Unlock...");
        digitalWrite(solenoidPin, HIGH); // Engage MOSFET 
        
        client.publish(topic_status, "UNLOCKED_PULSE");
        
        delay(2000); // 2-second safety pulse 
        
        digitalWrite(solenoidPin, LOW); // Disengage 
        client.publish(topic_status, "LOCKED");
        Serial.println("[STATUS] Auto-Relocked");
    } 
    else if (message == "LOCK" || message == "L") {
        digitalWrite(solenoidPin, LOW); // Force Secure 
        client.publish(topic_status, "LOCKED");
        Serial.println("[STATUS] Forced Lock Confirmed");
    }
}

// --- 5. SECURE RECONNECTION LOGIC ---
void reconnect() {
    while (!client.connected()) {
        Serial.print("Attempting STRICT mTLS Lock connection...");
        if (client.connect(mqtt_client_id)) {
            Serial.println("connected securely!");
            client.publish(topic_status, "LOCKED_BOOT"); // Publish boot state
            client.subscribe(topic_cmd); // Re-subscribe to commands
            Serial.println("Subscribed to command topic.");
        } else {
            Serial.print("failed, rc=");
            Serial.print(client.state());
            delay(5000);
        }
    }
}

// --- 6. MAIN SETUP & LOOP ---
void setup() {
    setCpuFrequencyMhz(80); // Underclock for 3x AA stability 
    
    pinMode(solenoidPin, OUTPUT);
    digitalWrite(solenoidPin, LOW); // FAIL-SAFE: Start LOCKED 
    
    Serial.begin(115200);
    
    unsigned long startAttemptTime = millis();
    while (!Serial && millis() - startAttemptTime < 2000) { delay(100); }
    
    setup_wifi();
    syncTime();

    // Load Security Trio
    espClient.setCACert(root_ca);
    espClient.setCertificate(client_cert);
    espClient.setPrivateKey(client_key);
    
    // Increased timeout to 60s for 80MHz CPU RSA math
    espClient.setHandshakeTimeout(60); 

    client.setServer(mqtt_server, 8883); // Secure Port
    client.setCallback(callback);
    
    Serial.println("Secure Lock Node Active.");
}

void loop() {
    if (!client.connected()) reconnect();
    client.loop();
    delay(20); // Allow system to idle in Light Sleep
}
