WiFiClientSecure espClient;
PubSubClient client(espClient);

// --- 3. HELPER FUNCTIONS ---

void syncTime() {
  configTime(0, 0, "pool.ntp.org", "time.google.com");
  Serial.print("Syncing Clock for TLS: ");
  time_t now = time(nullptr);
  while (now < 1672531200) { 
    delay(500);
    Serial.print(".");
    now = time(nullptr);
  }
  Serial.println("\n[OK] Time Synced.");
}

void setup_wifi() {
  delay(10);
  Serial.print("Connecting to WiFi...");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) { 
    delay(500); 
    Serial.print(".");
  }
  Serial.println("\nWiFi connected.");
}

void reconnect() {
  while (!client.connected()) {
    Serial.print("Attempting STRICT mTLS connection...");
    if (client.connect(mqtt_client_id)) {
      Serial.println("CONNECTED SECURELY!");
      // Re-send state upon reconnection to ensure Pi is synced
      String payload = isDaytime ? "Day" : "Night";
      client.publish(mqtt_publish_topic, payload.c_str());
    } else {
      Serial.print("failed, rc=");
      Serial.print(client.state());
      Serial.println(" - Retrying in 5s...");
      delay(5000); 
    }
  }
}

// --- 4. MAIN LOGIC ---

void setup() {
  Serial.begin(115200);
  analogSetAttenuation(ADC_11db); 
  
  setup_wifi();
  syncTime();

  // Load the Security Trio
  espClient.setCACert(root_ca); 
  espClient.setCertificate(client_cert); 
  espClient.setPrivateKey(client_key);   
  
  // ESP32 v3.0 Handshake fix
  espClient.setHandshakeTimeout(45); 

  client.setServer(mqtt_server, 8883); // Using secure port
  Serial.println("Living Room Light Secure Monitor Active.");
}

void loop() {
  if (!client.connected()) reconnect();
  client.loop();

  int currentRead = analogRead(lightSensorPin);

  // Logic with hysteresis 
  if (!isDaytime && (currentRead > (threshold + hysteresis))) {
    isDaytime = true;
  } 
  else if (isDaytime && (currentRead < (threshold - hysteresis))) {
    isDaytime = false;
  }

  // Publish when there is a change or on boot
  if (isDaytime != lastState || firstRun) {
    String payload = isDaytime ? "Day" : "Night";
    
    Serial.print("Secure State Change Detected: ");
    Serial.println(payload);
    
    // Publishing to the specific state topic
    client.publish(mqtt_publish_topic, payload.c_str());
    
    lastState = isDaytime;
    firstRun = false; 
  }

  delay(500); // Check twice a second
}
