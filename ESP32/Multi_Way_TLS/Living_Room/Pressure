WiFiClientSecure espClient; 
PubSubClient client(espClient);

// --- 3. HELPER FUNCTIONS ---

void syncTime() {
  configTime(0, 0, "pool.ntp.org", "time.google.com");
  Serial.print("Syncing Clock: ");
  time_t now = time(nullptr);
  while (now < 1672531200) { // Wait for year >= 2023
    delay(500);
    Serial.print(".");
    now = time(nullptr);
  }
  Serial.println("\n[OK] Time Synced.");
}

void setup_wifi() {
  Serial.print("Connecting to WiFi...");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi connected");
}

void reconnect() {
  while (!client.connected()) {
    Serial.print("Attempting STRICT mTLS connection...");
    if (client.connect(mqtt_client_id)) {
      Serial.println("CONNECTED SECURELY!");
    } else {
      Serial.print("failed, rc=");
      Serial.print(client.state());
      Serial.println(" - Retrying in 5s...");
      delay(5000);
    }
  }
}

// --- 4. SETUP AND LOOP ---

void setup() {
  Serial.begin(115200);
  setup_wifi();
  syncTime();
  
  // Load the Security Trio
  espClient.setCACert(root_ca); 
  espClient.setCertificate(client_cert); 
  espClient.setPrivateKey(client_key);   
  
  // ESP32 v3.0 Handshake fix
  espClient.setHandshakeTimeout(45); 

  client.setServer(mqtt_server, 8883); // Secure Port
  
  analogReadResolution(12);
  Serial.println("Living Room Secure Monitor Active.");
}

void loop() {
  if (!client.connected()) reconnect();
  client.loop();

  int rawValue = analogRead(pressurePin);
  int currentPressure = map(rawValue, 0, 4095, 0, 5000);

  if (abs(currentPressure - lastPressure) >= threshold) {
    String payload = String(currentPressure);
    
    // Fixed: Now uses the variable instead of a hardcoded string
    if (client.publish(mqtt_publish_topic, payload.c_str())) {
        Serial.print("Secure Data Sent -> Living Room Pressure: ");
        Serial.println(payload);
        lastPressure = currentPressure;
    } else {
        Serial.println("Secure Publish Failed!");
    }
  }
  delay(100); 
}
