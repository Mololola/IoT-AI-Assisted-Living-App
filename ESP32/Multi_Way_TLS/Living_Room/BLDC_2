// --- 3. HELPER FUNCTIONS ---

void syncTime() {
  configTime(0, 0, "pool.ntp.org", "time.google.com");
  Serial.print("Syncing Clock for TLS: ");
  time_t now = time(nullptr);
  while (now < 1672531200) { 
    delay(500);
    Serial.print(".");
    now = time(nullptr);
  }
  Serial.println("\n[OK] Time Synced.");
}

void setup_wifi() {
  delay(10);
  Serial.println("Connecting to WiFi...");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) { 
    delay(500); 
    Serial.print("."); 
  }
  Serial.println("\nWiFi connected");
}

void disableMotor() {
  digitalWrite(18, LOW); digitalWrite(19, LOW);
  digitalWrite(21, LOW); digitalWrite(22, LOW);
  Serial.println("Motor Relaxed (Power Saved)");
}

// --- 4. SECURE MQTT COMMAND HANDLER ---

void callback(char* topic, byte* payload, unsigned int length) {
  String message;
  for (int i = 0; i < length; i++) { message += (char)payload[i]; }
  message.toUpperCase();
  
  Serial.println("Secure Command arrived [" + String(topic) + "]: " + message);

  if (message == "OPEN") {
    Serial.println("Action: Opening Blinds...");
    myStepper.step(STEPS_PER_REV * 2); 
    disableMotor();
    
    String statusMsg = String(mqtt_client_id) + " OPENED";
    client.publish(topic_status, statusMsg.c_str());
  } 
  else if (message == "CLOSE") {
    Serial.println("Action: Closing Blinds...");
    myStepper.step(-STEPS_PER_REV * 2); 
    disableMotor();
    
    String statusMsg = String(mqtt_client_id) + " CLOSED";
    client.publish(topic_status, statusMsg.c_str());
  }
}

void reconnect() {
  while (!client.connected()) {
    Serial.print("Attempting STRICT mTLS connection...");
    if (client.connect(mqtt_client_id)) {
      Serial.println("connected securely!");
      client.subscribe(topic_cmd); // Listen for secure commands
      Serial.println("Subscribed to command topic.");
    } else {
      Serial.print("failed, rc=");
      Serial.print(client.state());
      delay(5000);
    }
  }
}

// --- 5. SETUP & LOOP ---

void setup() {
  Serial.begin(115200);
  myStepper.setSpeed(12);
  
  pinMode(18, OUTPUT); pinMode(19, OUTPUT);
  pinMode(21, OUTPUT); pinMode(22, OUTPUT);
  disableMotor(); // Start in relaxed state to save power

  setup_wifi();
  syncTime();

  // Load the Security Trio
  espClient.setCACert(root_ca); 
  espClient.setCertificate(client_cert); 
  espClient.setPrivateKey(client_key);   
  
  espClient.setHandshakeTimeout(45); 

  client.setServer(mqtt_server, 8883); // Secure Port
  client.setCallback(callback);
}

void loop() {
  if (!client.connected()) reconnect();
  client.loop();
}
