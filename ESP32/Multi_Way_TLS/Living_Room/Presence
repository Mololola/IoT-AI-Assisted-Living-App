// --- 3. HELPER FUNCTIONS ---

void syncTime() {
    configTime(0, 0, "pool.ntp.org", "time.google.com");
    Serial.print("Syncing Clock for TLS (May take longer at 80MHz): ");
    time_t now = time(nullptr);
    while (now < 1672531200) { 
        delay(500);
        Serial.print(".");
        now = time(nullptr);
    }
    Serial.println("\n[OK] Time Synced.");
}

void setup_wifi() {
    delay(10);
    Serial.println("Connecting to WiFi...");

    WiFi.setSleep(true); 
    WiFi.begin(ssid, password);
    
    int retry_count = 0;
    while (WiFi.status() != WL_CONNECTED && retry_count < 20) {
        delay(500);
        Serial.print(".");
        retry_count++;
    }
    
    if (WiFi.status() == WL_CONNECTED) {
       WiFi.setTxPower(WIFI_POWER_8_5dBm); 
       Serial.println("\nWiFi connected.");
    } else {
       Serial.println("\nWiFi Failed to Connect");
    }
}

void reconnect() {
    if (!client.connected()) {
        Serial.print("Attempting STRICT mTLS connection...");
        if (client.connect(mqtt_client_id)) {
            Serial.println("CONNECTED SECURELY!");
        } else {
            Serial.print("failed, rc=");
            Serial.print(client.state());
            delay(2000); 
        }
    }
}

void sendHexData(String hexString) {
    int hexStringLength = hexString.length();
    if (hexStringLength % 2 != 0) return;
 
    int byteCount = hexStringLength / 2;
    byte hexBytes[byteCount];
    for (int i = 0; i < hexStringLength; i += 2) {
        String byteString = hexString.substring(i, i + 2);
        byte hexByte = (byte)strtoul(byteString.c_str(), NULL, 16);
        hexBytes[i / 2] = hexByte;
    }
    HMMDSerial.write(hexBytes, byteCount); 
}

void readAndPublishData() {
    if (HMMDSerial.available() > 0) {
        String line = HMMDSerial.readStringUntil('\n');
        line.trim();

        if (line.startsWith("Range ")) {
            String distanceStr = line.substring(6); 
            float currentDistance = distanceStr.toFloat();
            
            float diff = abs(currentDistance - lastPublishedDistance);

            if (diff >= CHANGE_THRESHOLD_CM) {
                if (!client.connected()) reconnect();

                if (client.connected()) {
                    char payload[10];
                    dtostrf(currentDistance, 5, 2, payload); 
                    
                    client.publish(mqtt_publish_topic, payload);
                    
                    Serial.print(">>> SECURE CHANGE DETECTED (");
                    Serial.print(diff);
                    Serial.print("cm) | Sent: ");
                    Serial.println(payload);

                    lastPublishedDistance = currentDistance;
                }
            }
        }
    }
}

// --- 4. SETUP & LOOP ---

void setup() {
    // Power Saving: Drop CPU Speed to 80MHz
    setCpuFrequencyMhz(80); 

    Serial.begin(115200); 
    
    unsigned long startAttemptTime = millis();
    while (!Serial && millis() - startAttemptTime < 2000) { delay(100); }
    
    setup_wifi(); 
    syncTime();

    // Load Security Trio
    espClient.setCACert(root_ca);
    espClient.setCertificate(client_cert);
    espClient.setPrivateKey(client_key);
    
    // Increased timeout to 60s because 80MHz CPU handles RSA math slower
    espClient.setHandshakeTimeout(60); 

    client.setServer(mqtt_server, 8883); // Secure Port
    
    HMMDSerial.begin(HMMD_BAUDRATE, SERIAL_8N1, RX1_PIN, TX1_PIN);
    Serial.println("Sensor Serial Initialized");
    
    Serial.println("Sending Config Hex...");
    sendHexData(hex_to_send);
    
    delay(2000); 
    Serial.println("System Ready: Securely reporting on 5cm changes.");
}
    
void loop() {
    if (client.connected()) {
        client.loop(); 
    }

    readAndPublishData();
    
    delay(20);
}
