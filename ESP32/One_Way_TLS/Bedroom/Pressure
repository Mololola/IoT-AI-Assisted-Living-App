// --- 3. CLOCK SYNC FUNCTION ---
void syncTime() {
  // Set time via NTP using pool.ntp.org
  configTime(0, 0, "pool.ntp.org", "time.google.com");
  Serial.print("Waiting for NTP time sync: ");
  
  time_t now = time(nullptr);
  // 1672531200 is Jan 1st 2023. We wait until the year is at least 2023.
  while (now < 1672531200) {
    delay(500);
    Serial.print(".");
    now = time(nullptr);
  }
  Serial.println("\n[SUCCESS] Time Synced!");
}

void setup_wifi() {
  Serial.print("Connecting to WiFi...");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi connected");
}

void reconnect() {
  while (!client.connected()) {
    Serial.print("Attempting SECURE MQTT connection...");
    if (client.connect(mqtt_client_id)) {
      Serial.println("MQTT Connected SECURELY!");
    } else {
      Serial.print("failed, rc=");
      Serial.print(client.state());
      Serial.println(" try again in 5 seconds");
      delay(5000);
    }
  }
}

void setup() {
  Serial.begin(115200);
  setup_wifi();
  
  // NEW: Sync clock before starting TLS handshake
  syncTime();
  
  espClient.setCACert(root_ca);
  client.setServer(mqtt_server, 8883);
  
  analogReadResolution(12); //[cite: 1107]
  Serial.println("Secure Monitoring Active.");
}

void loop() {
  if (!client.connected()) reconnect();
  client.loop();

  int rawValue = analogRead(pressurePin);
  int currentPressure = map(rawValue, 0, 4095, 0, 5000);

  if (abs(currentPressure - lastPressure) >= threshold) {
    Serial.print("Change Detected! Pressure: ");
    Serial.println(currentPressure);

    String payload = String(currentPressure);
    client.publish(mqtt_publish_topic, payload.c_str());

    lastPressure = currentPressure;
  }
  delay(100); 
}
